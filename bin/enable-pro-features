#!/bin/bash
# Enable Pro Features for Self-Hosted DocuSeal
# This script is idempotent - safe to run multiple times after git pull

set -e

DOCUSEAL_ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$DOCUSEAL_ROOT"

echo "=== DocuSeal Pro Features Enabler ==="
echo "Working directory: $DOCUSEAL_ROOT"
echo ""

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Track changes
CHANGES_MADE=0

# Function to check if file contains pattern
file_contains() {
    grep -q "$1" "$2" 2>/dev/null
}

# Function to backup file before modification
backup_file() {
    local file="$1"
    if [[ ! -f "$file.bak" ]]; then
        cp "$file" "$file.bak"
        echo "Backed up: $file"
    fi
}

echo "[Phase 1] Setting up custom product name..."

# 1.1 Modify PRODUCT_NAME to use env var in lib/docuseal.rb
if file_contains "PRODUCT_NAME = 'DocuSeal'" "lib/docuseal.rb"; then
    backup_file "lib/docuseal.rb"
    sed -i "s/PRODUCT_NAME = 'DocuSeal'/PRODUCT_NAME = ENV.fetch('PRODUCT_NAME', 'DocuSeal')/g" "lib/docuseal.rb"
    echo -e "${GREEN}✓${NC} Updated PRODUCT_NAME to use env var"
    CHANGES_MADE=1
else
    echo -e "${YELLOW}⚠${NC} PRODUCT_NAME already modified or not found"
fi

# 1.2 Add PRODUCT_EMAIL_URL env var support
if ! file_contains "PRODUCT_EMAIL_URL = ENV.fetch" "lib/docuseal.rb"; then
    backup_file "lib/docuseal.rb"
    sed -i "s/PRODUCT_EMAIL_URL = \"\${PRODUCT_URL}\/newsletters\".freeze/PRODUCT_EMAIL_URL = ENV.fetch('PRODUCT_EMAIL_URL', PRODUCT_URL)/g" "lib/docuseal.rb"
    echo -e "${GREEN}✓${NC} Updated PRODUCT_EMAIL_URL to use env var"
    CHANGES_MADE=1
else
    echo -e "${YELLOW}⚠${NC} PRODUCT_EMAIL_URL already modified"
fi

echo ""
echo "[Phase 2] Enabling advanced document formats..."

# 2.1 Change advanced_formats? to return true
if file_contains "def advanced_formats?" "lib/docuseal.rb" && file_contains "multitenant?" "lib/docuseal.rb"; then
    backup_file "lib/docuseal.rb"
    # Replace the multitenant? check with true
    sed -i '/def advanced_formats?/,/end/{s/multitenant?/true/g}' "lib/docuseal.rb"
    echo -e "${GREEN}✓${NC} Enabled advanced document formats (.docx, .xlsx, etc.)"
    CHANGES_MADE=1
else
    echo -e "${YELLOW}⚠${NC} Advanced formats already enabled or method structure changed"
fi

echo ""
echo "[Phase 3] Updating hardcoded 'DocuSeal' strings..."

# 3.1 Update shared/_title.html.erb
if file_contains "<span>DocuSeal</span>" "app/views/shared/_title.html.erb"; then
    backup_file "app/views/shared/_title.html.erb"
    sed -i "s/<span>DocuSeal<\/span>/<span><%= Docuseal.product_name %><\/span>/g" "app/views/shared/_title.html.erb"
    echo -e "${GREEN}✓${NC} Updated shared/_title.html.erb"
    CHANGES_MADE=1
fi

# 3.2 Update start_form/_docuseal_logo.html.erb
if file_contains ">DocuSeal<" "app/views/start_form/_docuseal_logo.html.erb"; then
    backup_file "app/views/start_form/_docuseal_logo.html.erb"
    sed -i "s/>DocuSeal</><%= Docuseal.product_name %></g" "app/views/start_form/_docuseal_logo.html.erb"
    echo -e "${GREEN}✓${NC} Updated start_form/_docuseal_logo.html.erb"
    CHANGES_MADE=1
fi

# 3.3 Update pages/landing.html.erb
if file_contains ">DocuSeal<" "app/views/pages/landing.html.erb"; then
    backup_file "app/views/pages/landing.html.erb"
    sed -i "s/>DocuSeal</><%= Docuseal.product_name %></g" "app/views/pages/landing.html.erb"
    echo -e "${GREEN}✓${NC} Updated pages/landing.html.erb"
    CHANGES_MADE=1
fi

# 3.4 Update _head_tags.html.erb
if file_contains "'DocuSeal'" "app/views/layouts/_head_tags.html.erb"; then
    backup_file "app/views/layouts/_head_tags.html.erb"
    sed -i "s/'DocuSeal'/Docuseal.product_name/g" "app/views/layouts/_head_tags.html.erb"
    sed -i "s/'DocuSeal | Open Source Document Signing'/\"#{Docuseal.product_name} | Open Source Document Signing\"/g" "app/views/layouts/_head_tags.html.erb"
    echo -e "${GREEN}✓${NC} Updated layouts/_head_tags.html.erb"
    CHANGES_MADE=1
fi

# 3.5 Update _meta.html.erb
if file_contains "'DocuSeal'" "app/views/shared/_meta.html.erb"; then
    backup_file "app/views/shared/_meta.html.erb"
    sed -i "s/'DocuSeal'/Docuseal.product_name/g" "app/views/shared/_meta.html.erb"
    sed -i "s/'DocuSeal | Open Source Document Signing'/\"#{Docuseal.product_name} | Open Source Document Signing\"/g" "app/views/shared/_meta.html.erb"
    echo -e "${GREEN}✓${NC} Updated shared/_meta.html.erb"
    CHANGES_MADE=1
fi

# 3.6 Update start form views
for file in "app/views/start_form/show.html.erb" "app/views/start_form/email_verification.html.erb" "app/views/start_form/private.html.erb"; do
    if [[ -f "$file" ]] && file_contains "| DocuSeal" "$file"; then
        backup_file "$file"
        sed -i "s/| DocuSeal\"/#{Docuseal.product_name}\"/g" "$file"
        echo -e "${GREEN}✓${NC} Updated $(basename $file)"
        CHANGES_MADE=1
    fi
done

# 3.7 Update submit form views
for file in "app/views/submit_form/show.html.erb" "app/views/submit_form/email_2fa.html.erb"; do
    if [[ -f "$file" ]] && file_contains "| DocuSeal" "$file"; then
        backup_file "$file"
        sed -i "s/| DocuSeal\"/#{Docuseal.product_name}\"/g" "$file"
        echo -e "${GREEN}✓${NC} Updated $(basename $file)"
        CHANGES_MADE=1
    fi
done

echo ""
echo "[Phase 4] Updating signature reason and branding strings..."

# 4.1 Update SIGN_REASON in generate_result_attachments.rb
if file_contains "SIGN_REASON = 'Signed with DocuSeal.com'" "lib/submissions/generate_result_attachments.rb"; then
    backup_file "lib/submissions/generate_result_attachments.rb"
    sed -i "s/SIGN_REASON = 'Signed with DocuSeal.com'/SIGN_REASON = \"Signed with #{Docuseal.product_name}\"/g" "lib/submissions/generate_result_attachments.rb"
    echo -e "${GREEN}✓${NC} Updated generate_result_attachments.rb SIGN_REASON"
    CHANGES_MADE=1
fi

# 4.2 Update sign_reason in generate_audit_trail.rb
if file_contains "'Signed with DocuSeal.com'" "lib/submissions/generate_audit_trail.rb"; then
    backup_file "lib/submissions/generate_audit_trail.rb"
    sed -i "s/'Signed with DocuSeal.com'/\"Signed with #{Docuseal.product_name}\"/g" "lib/submissions/generate_audit_trail.rb"
    echo -e "${GREEN}✓${NC} Updated generate_audit_trail.rb sign_reason"
    CHANGES_MADE=1
fi

# 4.3 Update webhook user agent
if file_contains "USER_AGENT = 'DocuSeal.com Webhook'" "lib/send_webhook_request.rb"; then
    backup_file "lib/send_webhook_request.rb"
    sed -i "s/USER_AGENT = 'DocuSeal.com Webhook'/USER_AGENT = \"#{Docuseal.product_name} Webhook\"/g" "lib/send_webhook_request.rb"
    echo -e "${GREEN}✓${NC} Updated send_webhook_request.rb USER_AGENT"
    CHANGES_MADE=1
fi

if file_contains "USER_AGENT = 'DocuSeal.com Webhook'" "app/jobs/send_test_webhook_request_job.rb"; then
    backup_file "app/jobs/send_test_webhook_request_job.rb"
    sed -i "s/USER_AGENT = 'DocuSeal.com Webhook'/USER_AGENT = \"#{Docuseal.product_name} Webhook\"/g" "app/jobs/send_test_webhook_request_job.rb"
    echo -e "${GREEN}✓${NC} Updated send_test_webhook_request_job.rb USER_AGENT"
    CHANGES_MADE=1
fi

# 4.4 Update MCP name
if file_contains "name: 'DocuSeal'" "lib/mcp/handle_request.rb"; then
    backup_file "lib/mcp/handle_request.rb"
    sed -i "s/name: 'DocuSeal'/name: Docuseal.product_name/g" "lib/mcp/handle_request.rb"
    echo -e "${GREEN}✓${NC} Updated mcp/handle_request.rb server name"
    CHANGES_MADE=1
fi

# 4.5 Update esign cert name
if file_contains "DEFAULT_CERT_NAME = 'DocuSeal Self-Host Autogenerated'" "app/controllers/esign_settings_controller.rb"; then
    backup_file "app/controllers/esign_settings_controller.rb"
    sed -i "s/DEFAULT_CERT_NAME = 'DocuSeal Self-Host Autogenerated'/DEFAULT_CERT_NAME = \"#{Docuseal.product_name} Self-Host Autogenerated\"/g" "app/controllers/esign_settings_controller.rb"
    echo -e "${GREEN}✓${NC} Updated esign_settings_controller.rb cert name"
    CHANGES_MADE=1
fi

# 4.6 Update email sender
if file_contains "default from: 'DocuSeal <info@docuseal.com>'" "app/mailers/application_mailer.rb"; then
    backup_file "app/mailers/application_mailer.rb"
    sed -i "s/default from: 'DocuSeal <info@docuseal.com>'/default from: -> { \"#{Docuseal.product_name} <#{ENV.fetch('MAIL_FROM_ADDRESS', 'info@docuseal.com')}>\" }/g" "app/mailers/application_mailer.rb"
    echo -e "${GREEN}✓${NC} Updated application_mailer.rb sender"
    CHANGES_MADE=1
fi

echo ""
echo "[Phase 5] Adding custom logo support..."

# 5.1 Add has_one_attached :logo to Account model
if [[ -f "app/models/account.rb" ]] && ! file_contains "has_one_attached :logo" "app/models/account.rb"; then
    backup_file "app/models/account.rb"
    # Add after the last has_many or has_one line
    sed -i '/has_many :active_users/,/end/{n;a\\  has_one_attached :logo, dependent: :purge_later
}' "app/models/account.rb"
    echo -e "${GREEN}✓${NC} Added has_one_attached :logo to Account model"
    CHANGES_MADE=1
fi

# 5.2 Create LogoSettingsController if it doesn't exist
LOGO_CONTROLLER="app/controllers/logo_settings_controller.rb"
if [[ ! -f "$LOGO_CONTROLLER" ]]; then
cat > "$LOGO_CONTROLLER" << 'EOF'
# frozen_string_literal: true

class LogoSettingsController < ApplicationController
  before_action :authenticate_user!

  def create
    authorize!(:update, AccountConfig)

    current_account.logo.purge if current_account.logo.attached?

    if params[:logo].present? && current_account.logo.attach(params[:logo])
      redirect_to settings_personalization_path, notice: I18n.t('logo_updated')
    else
      redirect_to settings_personalization_path, alert: I18n.t('invalid_logo_file')
    end
  end

  def destroy
    authorize!(:update, AccountConfig)

    current_account.logo.purge
    redirect_to settings_personalization_path, notice: I18n.t('logo_removed')
  end
end
EOF
    echo -e "${GREEN}✓${NC} Created logo_settings_controller.rb"
    CHANGES_MADE=1
else
    echo -e "${YELLOW}⚠${NC} LogoSettingsController already exists"
fi

# 5.3 Add logo_settings route
if [[ -f "config/routes.rb" ]] && ! file_contains "logo_settings" "config/routes.rb"; then
    backup_file "config/routes.rb"
    # Add route after personalization line
    sed -i "/resource :personalization, only: %i\[show create\], controller: 'personalization_settings'/a\\\    resource :logo_settings, only: %i[create destroy]" "config/routes.rb"
    echo -e "${GREEN}✓${NC} Added logo_settings route"
    CHANGES_MADE=1
fi

# 5.4 Create logo form view
LOGO_FORM="app/views/personalization_settings/_logo_form.html.erb"
if [[ ! -f "$LOGO_FORM" ]] || file_contains "logo_placeholder" "$LOGO_FORM"; then
    backup_file "$LOGO_FORM" 2>/dev/null || true
    cat > "$LOGO_FORM" << 'EOF'
<div class="card bg-base-100">
  <div class="card-body">
    <% if current_account.logo.attached? %>
      <div class="flex items-center space-x-4 mb-4">
        <%= image_tag current_account.logo, class: 'h-16 w-auto object-contain' %>
        <div>
          <p class="text-sm text-gray-500"><%= t('current_logo') %></p>
          <%= button_to t('remove_logo'), settings_logo_settings_path, method: :delete, class: 'btn btn-error btn-sm mt-2', data: { turbo_confirm: t('are_you_sure') } %>
        </div>
      </div>
    <% end %>

    <%= form_with url: settings_logo_settings_path, method: :post, multipart: true do |f| %>
      <div class="form-control">
        <%= f.label :logo, t('upload_logo'), class: 'label' %>
        <%= f.file_field :logo, accept: 'image/*', class: 'file-input file-input-bordered w-full', required: !current_account.logo.attached? %>
        <label class="label">
          <span class="label-text-alt"><%= t('logo_recommended_size') %>: 200x200px, SVG/PNG/JPG</span>
        </label>
      </div>
      <div class="mt-4">
        <%= f.submit t('upload'), class: 'btn btn-primary' %>
      </div>
    <% end %>
  </div>
</div>
EOF
    echo -e "${GREEN}✓${NC} Created logo upload form"
    CHANGES_MADE=1
fi

echo ""
echo "[Phase 6] Creating logo helper and updating logo partials..."

# 6.1 Create custom_logo helper module
LOGO_HELPER="app/helpers/logo_helper.rb"
if [[ ! -f "$LOGO_HELPER" ]]; then
cat > "$LOGO_HELPER" << 'EOF'
# frozen_string_literal: true

module LogoHelper
  def account_logo_image(account, opts = {})
    return default_logo_svg(opts) unless account&.logo&.attached?

    image_tag(url_for(account.logo), opts.merge(class: opts[:class], width: opts[:width], height: opts[:height]))
  end

  def default_logo_svg(opts = {})
    width = opts.fetch(:width, '37')
    height = opts.fetch(:height, '37')
    css_class = opts[:class]

    content_tag(:svg, class: css_class, height: height, width: width, style: 'color: #e97a42', viewBox: '0 0 180 180', xmlns: 'http://www.w3.org/2000/svg') do
      safe_join([
        content_tag(:path, '', fill: 'currentColor', d: 'M 178.224 72.09 c -0.296 -1.463 -0.627 -2.919 -0.996 -4.364 -0.293 -1.151 -0.616 -2.293 -0.956 -3.433 -0.301 -1.008 -0.612 -2.014 -0.95 -3.012 -0.531 -1.578 -1.113 -3.142 -1.735 -4.694 -0.216 -0.54 -0.433 -1.082 -0.661 -1.618 -0.195 -0.462 -0.399 -0.917 -0.601 -1.375 -0.262 -0.591 -0.53 -1.177 -0.804 -1.762 -0.074 -0.159 -0.151 -0.315 -0.226 -0.474 -0.209 -0.441 -0.422 -0.881 -0.638 -1.318 -0.076 -0.154 -0.153 -0.306 -0.229 -0.459 -0.236 -0.471 -0.477 -0.939 -0.721 -1.406 -0.053 -0.101 -0.105 -0.201 -0.158 -0.302 -1.143 -2.16 -2.367 -4.269 -3.68 -6.322 -0.116 -0.181 -0.237 -0.359 -0.355 -0.539 -0.094 -0.144 -0.189 -0.288 -0.284 -0.432 -0.284 -0.431 -0.57 -0.861 -0.862 -1.287 -0.112 -0.164 -0.225 -0.326 -0.338 -0.489 -0.193 -0.279 -0.382 -0.56 -0.579 -0.836 -0.089 -0.125 -0.182 -0.249 -0.273 -0.374 -0.13 -0.182 -0.264 -0.362 -0.395 -0.542 -0.277 -0.38 -0.556 -0.76 -0.838 -1.135 -0.15 -0.199 -0.303 -0.395 -0.454 -0.593 -0.21 -0.274 -0.417 -0.552 -0.63 -0.823 -0.055 -0.069 -0.111 -0.136 -0.166 -0.205 -0.482 -0.61 -0.971 -1.216 -1.47 -1.814 -0.129 -0.155 -0.262 -0.306 -0.392 -0.461 -0.402 -0.476 -0.808 -0.95 -1.22 -1.417 -0.186 -0.212 -0.375 -0.422 -0.563 -0.631 -0.384 -0.428 -0.773 -0.854 -1.167 -1.276 -0.176 -0.189 -0.351 -0.379 -0.529 -0.567 -0.564 -0.595 -1.134 -1.186 -1.716 -1.768 -1.091 -1.091 -2.207 -2.15 -3.346 -3.178 -1.016 -0.919 -2.05 -1.815 -3.103 -2.684 -0.772 -0.636 -1.557 -1.255 -2.348 -1.864 -3.465 -2.67 -7.112 -5.075 -10.927 -7.209 -2.869 -1.604 -5.83 -3.06 -8.883 -4.351 -2.443 -1.033 -4.922 -1.948 -7.428 -2.756 -8.879 -2.863 -18.13 -4.318 -27.605 -4.318 -3.19 0 -6.354 0.169 -9.488 0.496 -4.036 0.421 -8.019 1.114 -11.94 2.073 -1.732 0.423 -3.452 0.892 -5.157 1.42 -2.856 0.883 -5.673 1.912 -8.447 3.085 -2.645 1.118 -5.222 2.357 -7.729 3.711 -2.574 1.39 -5.073 2.901 -7.494 4.533 -1.195 0.805 -2.37 1.64 -3.527 2.503 -1.156 0.864 -2.292 1.756 -3.408 2.676 -0.553 0.456 -1.1 0.919 -1.643 1.389 -1.649 1.