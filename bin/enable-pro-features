        content_tag(:circle, '', fill: 'currentColor', cx: '71.927', cy: '32.004', r: '2.829')
      ])
    end
  end
end
EOF
    echo -e "${GREEN}✓${NC} Created logo_helper.rb"
    CHANGES_MADE=1
fi

# 6.2 Update shared/_logo.html.erb to use helper
if [[ -f "app/views/shared/_logo.html.erb" ]]; then
    backup_file "app/views/shared/_logo.html.erb"
    # Replace with helper call if not already using account context
    # This is a view-level change - the original has hardcoded SVG
    # We'll check if it needs updating based on current content
    echo -e "${YELLOW}⚠${NC} shared/_logo.html.erb has hardcoded SVG. For full logo customization, run the Ruby helper version."
fi

echo ""
echo "[Phase 7] Adding hide_powered_by support..."

# 7.1 Add hide_powered_by? method to docuseal.rb
if [[ -f "lib/docuseal.rb" ]] && ! file_contains "def hide_powered_by?" "lib/docuseal.rb"; then
    backup_file "lib/docuseal.rb"
    # Add before the last 'end'
    sed -i '/^end$/i\\\  def hide_powered_by?\n    ENV["HIDE_POWERED_BY"] == "true"\n  end\n' "lib/docuseal.rb"
    echo -e "${GREEN}✓${NC} Added hide_powered_by? method to docuseal.rb"
    CHANGES_MADE=1
fi

# 7.2 Update _powered_by.html.erb to conditionally hide
if [[ -f "app/views/shared/_powered_by.html.erb" ]] && ! file_contains "hide_powered_by?" "app/views/shared/_powered_by.html.erb"; then
    backup_file "app/views/shared/_powered_by.html.erb"
    # Wrap entire content in unless block
    sed -i '1s/^/<% unless Docuseal.hide_powered_by? %>\n/' "app/views/shared/_powered_by.html.erb"
    echo '<% end %>' >> "app/views/shared/_powered_by.html.erb"
    echo -e "${GREEN}✓${NC} Updated _powered_by.html.erb with hide support"
    CHANGES_MADE=1
fi

# 7.3 Update email attribution similarly
if [[ -f "app/views/shared/_email_attribution.html.erb" ]] && ! file_contains "hide_powered_by?" "app/views/shared/_email_attribution.html.erb"; then
    backup_file "app/views/shared/_email_attribution.html.erb"
    sed -i '1s/^/<% unless Docuseal.hide_powered_by? %>\n/' "app/views/shared/_email_attribution.html.erb"
    echo '<% end %>' >> "app/views/shared/_email_attribution.html.erb"
    echo -e "${GREEN}✓${NC} Updated _email_attribution.html.erb with hide support"
    CHANGES_MADE=1
fi

echo ""
echo "[Phase 8] Updating PDF generation for custom logos..."

# 8.1 Update generate_audit_trail.rb add_logo method
if [[ -f "lib/submissions/generate_audit_trail.rb" ]] && file_contains "def add_logo(column, _submission = nil)" "lib/submissions/generate_audit_trail.rb"; then
    backup_file "lib/submissions/generate_audit_trail.rb"
    # This is complex - use a heredoc to create a patch
    python3 << 'PYTHON_SCRIPT'
import re

with open('lib/submissions/generate_audit_trail.rb', 'r') as f:
    content = f.read()

old_method = '''def add_logo(column, _submission = nil)
    column.image(PdfIcons.logo_io, width: 40, height: 40, position: :float)

    column.formatted_text([{ text: 'DocuSeal',
                             link: Docuseal::PRODUCT_EMAIL_URL }],'''

new_method = '''def add_logo(column, submission = nil)
    logo_io = if submission&.account&.logo&.attached?
                StringIO.new(submission.account.logo.download)
              else
                PdfIcons.logo_io
              end

    column.image(logo_io, width: 40, height: 40, position: :float)

    column.formatted_text([{ text: Docuseal.product_name,
                             link: Docuseal::PRODUCT_EMAIL_URL }],'''

if 'def add_logo(column, _submission = nil)' in content and "text: 'DocuSeal'" in content:
    content = content.replace(old_method, new_method)
    with open('lib/submissions/generate_audit_trail.rb', 'w') as f:
        f.write(content)
    print('Updated add_logo method')
else:
    print('Method already updated or structure changed')
PYTHON_SCRIPT
    echo -e "${GREEN}✓${NC} Updated generate_audit_trail.rb add_logo method"
    CHANGES_MADE=1
fi

# 8.2 Update create_stamp_attachment.rb load_logo method
if [[ -f "lib/submitters/create_stamp_attachment.rb" ]]; then
    backup_file "lib/submitters/create_stamp_attachment.rb"
    python3 << 'PYTHON_SCRIPT'
import re

with open('lib/submitters/create_stamp_attachment.rb', 'r') as f:
    content = f.read()

old_method = '''def load_logo(_submitter)
    PdfIcons.stamp_logo_io
  end'''

new_method = '''def load_logo(submitter)
    if submitter&.account&.logo&.attached?
      submitter.account.logo.download
    else
      PdfIcons.stamp_logo_io.read
    end
  end'''

if 'def load_logo(_submitter)' in content:
    content = content.replace(old_method, new_method)
    with open('lib/submitters/create_stamp_attachment.rb', 'w') as f:
        f.write(content)
    print('Updated load_logo method')
else:
    print('Method already updated or not found')
PYTHON_SCRIPT
    echo -e "${GREEN}✓${NC} Updated create_stamp_attachment.rb load_logo method"
    CHANGES_MADE=1
fi

echo ""
echo "========================================"
if [ $CHANGES_MADE -eq 1 ]; then
    echo -e "${GREEN}✓ Pro features enabled successfully!${NC}"
    echo ""
    echo "Environment variables to set in your .env file:"
    echo "  PRODUCT_NAME=MySignApp"
    echo "  HIDE_POWERED_BY=true"
    echo "  MAIL_FROM_ADDRESS=noreply@mydomain.com"
    echo ""
    echo "Next steps:"
    echo "  1. Set environment variables in your .env or docker-compose.yml"
    echo "  2. Restart your DocuSeal server"
    echo "  3. Go to Settings > Personalization to upload your custom logo"
    echo ""
    echo -e "${YELLOW}Note:${NC} This script can be safely re-run after git pull"
else
    echo -e "${YELLOW}⚠ No changes needed - features already enabled${NC}"
fi
echo "========================================"
